{
  "builds": [
    { 
      "src": "app/main.py", 
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    { 
      "src": "/api/(.*)", 
      "dest": "app/main.py" 
    },
    { 
      "src": "/health", 
      "dest": "app/main.py" 
    },
    { 
      "src": "/", 
      "dest": "app/main.py" 
    }
  ],
  "env": {
    "OLLAMA_URL": "@ollama_url",
    "WEBHOOK_URL": "@webhook_url"
  },
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "echo 'Backend build complete'"
}
